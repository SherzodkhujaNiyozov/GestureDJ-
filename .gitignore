# ---- Python virtual environment ----
.venv/
venv/
env/

# ---- Python bytecode / caches ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- PyInstaller build artifacts ----
build/
dist/
*.spec

# ---- Runtime-generated files (yuklab olinadi / yaratiladi) ----
models/              # hand_landmarker.task birinchi ishga tushishda yuklanadi
logs/                # diagnostika loglari
config.json          # foydalanuvchi sozlamalari
config.tmp           # config'ning atomik yozuvi (vaqtinchalik)
*.part               # tugallanmagan yuklamalar

# ---- Release artifacts ----
*.zip
GestureDJ-*.zip

# ---- Editor / IDE ----
.vscode/
.idea/
*.swp
*~

# ---- OS junk ----
Thumbs.db
Desktop.ini
.DS_Store

# ---- AI agent skill (lokal, repoga kerak emas) ----
.claude/

# ---- Vaqtinchalik test fayllari ----
_test_*.py
